<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="SimDesk"
           Language="1033"
           Version="0.1.0"
           Manufacturer="SimDesk"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Comments="Windows 桌面整理工具" />

    <!-- 允许升级 -->
    <MajorUpgrade DowngradeErrorMessage="已安装更新版本。" />

    <Media Id="1" Cabinet="simdesk.cab" EmbedCab="yes" />

    <!-- 安装目录: %ProgramFiles%\SimDesk -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="SimDesk">

          <!-- 主程序文件 -->
          <Component Id="AppFiles" Guid="B1B2C3D4-E5F6-7890-ABCD-EF1234567891">
            <File Id="AppExe" Name="SimDesk.App.exe" Source="publish\SimDesk\SimDesk.App.exe" KeyPath="yes" />
            <File Id="CoreDll" Name="SimDesk.Core.dll" Source="publish\SimDesk\SimDesk.Core.dll" />
          </Component>

          <!-- Shell 扩展子目录 -->
          <Directory Id="ShellExtDir" Name="ShellExt">
            <Component Id="ShellExtFiles" Guid="C1B2C3D4-E5F6-7890-ABCD-EF1234567892">
              <File Id="ShellComHost" Name="SimDesk.ShellExtension.comhost.dll"
                    Source="publish\ShellExt\SimDesk.ShellExtension.comhost.dll" KeyPath="yes" />
              <File Id="ShellDll" Name="SimDesk.ShellExtension.dll"
                    Source="publish\ShellExt\SimDesk.ShellExtension.dll" />
              <File Id="ShellCoreDll" Name="SimDesk.Core.dll"
                    Source="publish\ShellExt\SimDesk.Core.dll" />
            </Component>
          </Directory>

        </Directory>
      </Directory>

      <!-- 桌面快捷方式 -->
      <Directory Id="DesktopFolder" Name="Desktop">
        <Component Id="DesktopShortcut" Guid="D1B2C3D4-E5F6-7890-ABCD-EF1234567893">
          <Shortcut Id="DesktopSC" Name="SimDesk"
                    Target="[INSTALLDIR]SimDesk.App.exe"
                    WorkingDirectory="INSTALLDIR" />
          <RemoveFolder Id="RemoveDesktopFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\SimDesk"
                         Name="desktop_shortcut"
                         Type="integer" Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>

      <!-- 开始菜单 -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="StartMenuDir" Name="SimDesk">
          <Component Id="StartMenuShortcut" Guid="E1B2C3D4-E5F6-7890-ABCD-EF1234567894">
            <Shortcut Id="StartMenuSC" Name="SimDesk"
                      Target="[INSTALLDIR]SimDesk.App.exe"
                      WorkingDirectory="INSTALLDIR" />
            <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
            <RegistryValue Root="HKCU"
                           Key="Software\SimDesk"
                           Name="startmenu_shortcut"
                           Type="integer" Value="1"
                           KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>

    </Directory>

    <!-- 功能 -->
    <Feature Id="Main" Title="SimDesk" Level="1">
      <ComponentRef Id="AppFiles" />
      <ComponentRef Id="ShellExtFiles" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <!-- 安装时注册 COM -->
    <CustomAction Id="RegisterCOM"
                  Directory="INSTALLDIR"
                  ExeCommand='regsvr32 /s "[INSTALLDIR]ShellExt\SimDesk.ShellExtension.comhost.dll"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- 卸载时注销 COM -->
    <CustomAction Id="UnregisterCOM"
                  Directory="INSTALLDIR"
                  ExeCommand='regsvr32 /s /u "[INSTALLDIR]ShellExt\SimDesk.ShellExtension.comhost.dll"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <InstallExecuteSequence>
      <Custom Action="RegisterCOM" After="InstallFiles">NOT Installed</Custom>
      <Custom Action="UnregisterCOM" Before="RemoveFiles">Installed</Custom>
    </InstallExecuteSequence>

  </Product>
</Wix>
