<Window x:Class="SimDesk.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 SimDesk"
        Width="360" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="SimDesk" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
        <TextBlock Text="Windows 桌面整理工具"
                   FontSize="13" Foreground="#666"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="版本: 0.1.0" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2"/>
            <TextBlock Text="运行时: .NET 10.0" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2"/>
            <TextBlock Text="平台: Windows 10/11" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2"/>
        </StackPanel>

        <TextBlock FontSize="11" Foreground="#999"
                   HorizontalAlignment="Center" Margin="0,16,0,0">
            <Run Text="© 2026 SimDesk" />
        </TextBlock>

        <Button Content="确定" Width="80" Height="30" Margin="0,12,0,0"
                Click="OnOkClick" />
    </StackPanel>
</Window>
