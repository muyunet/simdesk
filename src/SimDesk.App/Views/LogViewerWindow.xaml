<Window x:Class="SimDesk.App.Views.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimDesk 日志"
        Width="800" Height="550"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <DockPanel Margin="10">
        <!-- 顶部筛选栏 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="筛选:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <ComboBox x:Name="EventTypeFilter" Width="120" FontSize="12"
                          SelectionChanged="OnFilterChanged">
                    <ComboBoxItem Content="全部事件" IsSelected="True" Tag="" />
                    <ComboBoxItem Content="创建" Tag="Create" />
                    <ComboBoxItem Content="纳入" Tag="Add" />
                    <ComboBoxItem Content="删除" Tag="Remove" />
                    <ComboBoxItem Content="解散" Tag="Dissolve" />
                </ComboBox>
                <ComboBox x:Name="BoxFilter" Width="160" FontSize="12" Margin="8,0,0,0"
                          SelectionChanged="OnFilterChanged">
                    <ComboBoxItem Content="全部收纳盒" IsSelected="True" />
                </ComboBox>
                <Button Content="刷新" Width="60" FontSize="12" Margin="8,0,0,0"
                        Click="OnRefresh" />
            </StackPanel>
        </StackPanel>

        <!-- 日志列表（事件分组 + 可展开文件详情） -->
        <TreeView x:Name="LogTreeView"
                  DockPanel.Dock="Top"
                  Height="380"
                  FontSize="12"
                  VirtualizingPanel.IsVirtualizing="True">
            <TreeView.Resources>
                <!-- 事件条目样式 -->
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="False" />
                </Style>
            </TreeView.Resources>
        </TreeView>

        <!-- 底部分页栏 -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="◀ 上一页" Width="70" FontSize="12" Margin="0,0,6,0"
                    Click="OnPrevPage" />
            <TextBlock x:Name="PageLabel" Text="第 1 页"
                       VerticalAlignment="Center" FontSize="12" Margin="6,0"/>
            <Button Content="下一页 ▶" Width="70" FontSize="12" Margin="6,0,0,0"
                    Click="OnNextPage" />
        </StackPanel>
    </DockPanel>
</Window>
