<Popup x:Class="SimDesk.App.Views.SettingsPopup"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       StaysOpen="False"
       AllowsTransparency="True"
       PopupAnimation="Fade"
       Placement="Bottom"
       Width="260">
    <Border Background="White"
            BorderBrush="#CCC"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8"
            Effect="{DynamicResource DropShadowEffect}">
        <StackPanel>
            <!-- ===== 第一类：显示方式 ===== -->
            <TextBlock Text="显示方式" FontWeight="Bold" Margin="0,4,0,2" FontSize="12" Foreground="#666"/>
            <StackPanel Margin="8,0,0,4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="IconsModeRb" Content="图标模式"
                                 GroupName="DisplayMode" IsChecked="True"
                                 Margin="0,2" FontSize="12" />
                    <RadioButton x:Name="ListModeRb" Content="列表模式"
                                 GroupName="DisplayMode"
                                 Margin="12,2" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="图标大小:" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                    <TextBox x:Name="IconSizeBox" Width="50" Text="48" FontSize="12"
                             VerticalContentAlignment="Center" />
                    <TextBlock Text="px" VerticalAlignment="Center" FontSize="11" Foreground="#999" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <Separator />

            <!-- ===== 排序方式 ===== -->
            <TextBlock Text="排序方式" FontWeight="Bold" Margin="0,4,0,2" FontSize="12" Foreground="#666"/>
            <StackPanel Margin="8,0,0,4">
                <WrapPanel>
                    <RadioButton Content="名称" GroupName="SortBy" Margin="0,2,8,2" FontSize="12" IsChecked="True"/>
                    <RadioButton Content="大小" GroupName="SortBy" Margin="0,2,8,2" FontSize="12"/>
                    <RadioButton Content="修改时间" GroupName="SortBy" Margin="0,2,8,2" FontSize="12"/>
                    <RadioButton Content="类型" GroupName="SortBy" Margin="0,2,8,2" FontSize="12"/>
                </WrapPanel>
                <CheckBox x:Name="SortAscendingCb" Content="升序" IsChecked="True" FontSize="12" Margin="0,2"/>
            </StackPanel>

            <Separator />

            <!-- ===== 第二类：外观 ===== -->
            <TextBlock Text="外观" FontWeight="Bold" Margin="0,4,0,2" FontSize="12" Foreground="#666"/>
            <StackPanel Margin="8,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="背景色:" VerticalAlignment="Center" FontSize="12" Width="55"/>
                    <Border x:Name="ColorPreview" Width="24" Height="24" CornerRadius="4"
                            Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1"
                            Cursor="Hand" MouseLeftButtonDown="OnPickColor" Margin="0,0,8,0"/>
                    <Button Content="选择..." FontSize="11" Padding="6,2" Click="OnPickColor" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2">
                    <TextBlock Text="背景图:" VerticalAlignment="Center" FontSize="12" Width="55"/>
                    <Button Content="选择图片..." FontSize="11" Padding="6,2" Click="OnPickImage" />
                    <Button Content="清除" FontSize="11" Padding="6,2" Margin="4,0,0,0"
                            Click="OnClearImage" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="透明度:" VerticalAlignment="Center" FontSize="12" Width="55"/>
                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" Value="0.92"
                            Width="120" SmallChange="0.05" LargeChange="0.1"
                            ValueChanged="OnOpacityChanged" />
                    <TextBlock x:Name="OpacityLabel" Text="92%" VerticalAlignment="Center"
                               FontSize="11" Margin="6,0,0,0" Width="30"/>
                </StackPanel>
            </StackPanel>

            <Separator />

            <!-- ===== 第三类：行为 ===== -->
            <TextBlock Text="行为" FontWeight="Bold" Margin="0,4,0,2" FontSize="12" Foreground="#666"/>
            <StackPanel Margin="8,0,0,4">
                <CheckBox x:Name="PositionLockedCb" Content="位置锁定" FontSize="12" Margin="0,2"/>
                <Button Content="隐藏收纳盒" FontSize="12" Padding="4,3"
                        HorizontalAlignment="Left" Margin="0,2"
                        Click="OnHideBox" />
                <Button Content="解散收纳盒" FontSize="12" Padding="4,3"
                        HorizontalAlignment="Left" Margin="0,2"
                        Foreground="#CC3333"
                        Click="OnDissolveBox" />
            </StackPanel>
        </StackPanel>
    </Border>
</Popup>
