<Window x:Class="SimDesk.App.Views.StorageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Transparent"
        MinWidth="200"
        MinHeight="50"
        Left="{Binding WindowPosition.X}"
        Top="{Binding WindowPosition.Y}"
        Width="{Binding WindowPosition.Width}"
        Height="{Binding WindowPosition.Height}"
        MouseLeftButtonDown="OnWindowMouseDown">

    <!-- 主边框：圆角 + 背景 + 透明度 -->
    <Border CornerRadius="8"
            Background="{Binding BackgroundBrush}"
            BorderBrush="#33000000"
            BorderThickness="1">
        <DockPanel>
            <!-- 标题栏 -->
            <Border x:Name="TitleBar"
                    DockPanel.Dock="Top"
                    Height="36"
                    Background="#E8E8E8"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 收纳盒名称 -->
                    <TextBlock x:Name="BoxNameText"
                               Grid.Column="0"
                               Text="{Binding Name}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               MouseLeftButtonDown="OnTitleBarMouseDown" />

                    <!-- 名称编辑框（双击后显示） -->
                    <TextBox x:Name="BoxNameEdit"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0"
                             FontSize="13"
                             Visibility="Collapsed"
                             KeyDown="OnNameEditKeyDown"
                             LostFocus="OnNameEditLostFocus" />

                    <!-- 右侧按钮组 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0">
                        <Button x:Name="SettingsButton"
                                Content="⚙"
                                Width="28" Height="28"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="OnSettingsClick"
                                ToolTip="设置" />
                        <Button x:Name="CollapseButton"
                                Content="▲"
                                Width="28" Height="28"
                                Style="{StaticResource TitleBarButtonStyle}"
                                Click="OnCollapseClick"
                                ToolTip="收起/展开" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 内容区域 -->
            <Border x:Name="ContentArea"
                    Background="{Binding ContentBackgroundBrush}">
                <!-- 初始为空，Phase 3 实现图标/列表视图 -->
                <TextBlock Text="收纳盒内容区域"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#999"
                           FontSize="14" />
            </Border>
        </DockPanel>
    </Border>
</Window>
